NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# SEO, sitemap, robots ve Open Graph — canlı: https://patisid.app (yerelde API için Host kullanılır)
NEXT_PUBLIC_SITE_URL=https://patisid.app

# JSON-LD sameAs — virgülle ayrılmış tam sosyal profil URL’leri (opsiyonel)
# NEXT_PUBLIC_SOCIAL_PROFILES=https://twitter.com/...,https://www.instagram.com/...

# Giriş / kayıt tam ekran arka plan: tam URL veya public dosyası (ör. /auth-bg.jpg)
# Fotoğrafı public/auth-bg.jpg olarak ekle ve:
# NEXT_PUBLIC_AUTH_HERO_IMAGE_URL=/auth-bg.jpg
# Boşsa varsayılan uzak görsel kullanılır.
# Mobil üst banner görseli (isteğe bağlı); ayarlıysa sadece <md üst şeritte kullanılır.
# NEXT_PUBLIC_AUTH_HERO_IMAGE_MOBILE_URL=/auth-bg-mobile.jpg

# Supabase Auth: Dashboard > Authentication > URL Configuration — Redirect URL olarak
# NEXT_PUBLIC_SITE_URL + /auth/callback

# Gorsel dogrulama: openai | ollama | mock (bos + OPENAI_API_KEY yoksa otomatik mock)
# VISION_PROVIDER=mock
# Ucretsiz yerel AI: https://ollama.com — `ollama pull llava` sonra:
# VISION_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llava

# Ileride Google Maps'e gecersen: Maps JavaScript API anahtari (simdilik Leaflet + OSM, gerek yok)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
